@page
@model Academy.Pages.Groups.DetailsModel

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Group</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Group.group_name)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Group.group_name)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Group.direction)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Group.Direction.direction_name)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Group.learning_days)
        </dt>
        <dd class="col-sm-10">
            @(new Week(Model.Group.learning_days))
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Group.start_time)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Group.start_time)
        </dd>
        <dt class="col-sm-2">
            Количество студентов:
        </dt>
        <dd class="col-sm-10">
            @Model.Group.Students.Count()
        </dd>
        @foreach (Models.Student s in Model.Group.Students)
        {
            <dt class="col-sm-2"/>
            <dd class="col-sm-10">
                @s.last_name @s.first_name @s.middle_name
            </dd>
        }
    </dl>
</div>
<div>
    <a asp-page="./Edit" asp-route-id="@Model.Group.group_id">Edit</a> |
    <a asp-page="./Index">Back to List</a>
</div>
