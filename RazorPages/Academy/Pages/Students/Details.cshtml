@page
@model Academy.Pages.Students.DetailsModel

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Student</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Student.last_name)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Student.last_name)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Student.first_name)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Student.first_name)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Student.middle_name)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Student.middle_name)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Student.birth_date)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Student.birth_date)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Student.email)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Student.email)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Student.phone)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Student.phone)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Student.Group)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Student.Group.group_name)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Student.photo)
        </dt>
        <dd class="col-sm-10">
            @if (Model.Student.photo?.Length > 0)
            {
                <img style="max-width:200px;height:auto;border:1px solid #dee2e6; border-radius:4px;"
                    src="data:image; base64, @Convert.ToBase64String(Model.Student.photo)" 
                    alt="Photo"/>
            }
        </dd>
    </dl>
</div>
<div>
    <a asp-page="./Edit" asp-route-id="@Model.Student.stud_id">Edit</a> |
    <a asp-page="./Index">Back to List</a>
</div>
