@page
@model Academy.Pages.Directions.CreateModel

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>Direction</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="All" class="text-danger"></div>
            <div class="form-group">
                <span class="text-danger">*</span>
                <label asp-for="Direction.direction_id" class="control-label"></label>
                <input asp-for="Direction.direction_id" class="form-control" aria-required="true"/>
                <span asp-validation-for="Direction.direction_id" class="text-danger"></span>
            </div>
            <div class="form-group">
                <span class="text-danger">*</span>
                <label asp-for="Direction.direction_name" class="control-label"></label>
                <input asp-for="Direction.direction_name" class="form-control" aria-required="true"/>
                <span asp-validation-for="Direction.direction_name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
