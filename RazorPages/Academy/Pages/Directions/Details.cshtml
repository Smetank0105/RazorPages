@page
@model Academy.Pages.Directions.DetailsModel

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Direction</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Direction.direction_name)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Direction.direction_name)
        </dd>
        <dt class="col-sm-2">
            Количество групп:
        </dt>
        <dd class="col-sm-10">
            @Model.Direction.Groups.Count()
        </dd>
        @foreach (Models.Group g in Model.Direction.Groups)
        {
            <dt class="col-sm-2" />
            <dd class="col-sm-10">
                @g.group_name
            </dd>
        }
    </dl>
</div>
<div>
    <a asp-page="./Edit" asp-route-id="@Model.Direction.direction_id">Edit</a> |
    <a asp-page="./Index">Back to List</a>
</div>
